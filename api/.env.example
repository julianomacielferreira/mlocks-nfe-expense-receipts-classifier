# === MODO DE OPERAÇÃO ===
# local = mock (sem IA), ollama = LLaMA 2 local
ENV=ollama

# === BANCO DE DADOS ===
# Use esta string quando rodar NO DOCKER (host 'database' é o nome do serviço)
DATABASE_URL=postgresql://postgres:qwerty@database:5432/mlocks_nferc_db

# === OLLAMA (LLaMA 2) ===
OLLAMA_URL=http://ollama:11434

# Para PyCharm local: OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama2:7b